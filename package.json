{
  "name": "streaming",
  "version": "1.0.0",
  "main": "dist/app.js",
  "packageManager": "pnpm@8.6.3",
  "scripts": {
    "dev": "nodemon --watch src --watch ../../shared/ --exec ts-node -r tsconfig-paths/register src/app.ts",
    "stage": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc -p tsconfig.json",
    "proto:generate": "pnpm exec protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=src/grpc/generated --ts_proto_opt=outputServices=grpc-js,useExactTypes=false,esModuleInterop=true --proto_path=../../proto/ ../../proto/*.proto ../../proto/**/*.proto",
    "start": "node ./dist/app.js",
    "test": "jest",
    "postinstall": "prisma generate --schema=./prisma/schema.prisma"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/supertest": "^7.2.0",
    "fast-glob": "^3.3.3",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2",
    "ts-proto": "^2.11.6",
    "@types/ws": "^8.5.10"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@bufbuild/protobuf": "^2.11.0",
    "@shared/grpc-client-manager": "workspace:*",
    "@shared/kafka-manager": "workspace:*",
    "@shared/pg-boss-manager": "workspace:*",
    "@shared/logger": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "@prisma/client": "^6.19.3",
    "jsonwebtoken": "^9.0.3",
    "pg-boss": "^12.15.0",
    "kafkajs": "^2.2.4",
    "ws": "^8.21.0"
  }
}
